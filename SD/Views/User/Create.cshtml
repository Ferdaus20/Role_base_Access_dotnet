@model SD.Models.User

@{
    ViewData["Title"] = "Register Account";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 border rounded p-4 shadow-sm bg-light">
        <h3 class="mb-4">Register New User</h3>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" type="email" autocomplete="off" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input name="plainPassword" type="password" class="form-control" required />
                <small class="text-muted">Password will be safely encrypted before saving.</small>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                <button type="submit" class="btn btn-success">Save User</button>
            </div>
        </form>
    </div>
</div>
