@model SD.Models.User

@{
    ViewData["Title"] = "Confirm Deletion";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 border border-danger rounded p-4 shadow-sm bg-white">
        <h3 class="text-danger mb-3">Delete User Account?</h3>
        <p class="lead text-muted">Are you absolutely sure you want to completely remove this user account? This action cannot be reversed.</p>

        <hr />

        <dl class="row my-4">
            @* <dt class="col-sm-4 font-weight-bold">User ID:</dt>
            <dd class="col-sm-8">@Model.Id</dd> *@

            <dt class="col-sm-4 font-weight-bold">Email Address:</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4 font-weight-bold">Joined On:</dt>
            <dd class="col-sm-8">@Model.CreatedAt.ToString("F")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">No, Go Back</a>
                <button type="submit" class="btn btn-danger">Yes, Delete Account</button>
            </div>
        </form>
    </div>
</div>
