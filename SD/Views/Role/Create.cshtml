@model SD.Models.Role

@{
    ViewData["Title"] = "Create Role";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 border rounded p-4 shadow-sm bg-light">
        <h3 class="mb-4">Create New Role</h3>
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Role Name</label>
                <input asp-for="Name" class="form-control" required placeholder="e.g. Admin, Editor" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">Back</a>
                <button type="submit" class="btn btn-success">Save Role</button>
            </div>
        </form>
    </div>
</div>
