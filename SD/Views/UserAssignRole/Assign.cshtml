@model SD.Models.UserAssignRole

@{
    ViewData["Title"] = "Assign Role";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 border rounded p-4 shadow-sm bg-light">
        <h3 class="mb-4">Assign Role to User</h3>

        <form asp-action="Assign" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Select User Email</label>
                <select asp-for="UserId" class="form-select" asp-items="ViewBag.Users" required>
                    <option value="">-- Choose User Account --</option>
                </select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Select Target Role</label>
                <select asp-for="RoleId" class="form-select" asp-items="ViewBag.Roles" required>
                    <option value="">-- Choose System Role --</option>
                </select>
                <span asp-validation-for="RoleId" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                <button type="submit" class="btn btn-success">Save Assignment</button>
            </div>
        </form>
    </div>
</div>
