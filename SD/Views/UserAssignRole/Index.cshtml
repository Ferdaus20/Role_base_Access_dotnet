@model IEnumerable<SD.Models.UserAssignRole>

@{
    ViewData["Title"] = "Role Assignments";
}

<div class="d-flex justify-content-between align-items-center my-4">
    <h2>User Role Mapping</h2>
    <a asp-action="Assign" class="btn btn-success">Assign New Role</a>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>User Email</th>
            <th>Assigned Role</th>
            <th>Assignment Date</th>
            <th class="text-center">Action</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="4" class="text-center text-muted">No custom operational roles mapped to accounts yet.</td>
            </tr>
        }
        else
        {
            @foreach (var map in Model)
            {
                <tr>
                    <td>@map.User?.Email</td>
                    <td><span class="badge bg-primary px-2 py-1">@map.Role?.Name</span></td>
                    <td>@map.AssignedAt.ToString("g")</td>
                    <td class="text-center">
                        <form asp-action="Revoke" method="post" onsubmit="return confirm('Revoke this role?');" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@map.UserId" />
                            <input type="hidden" name="roleId" value="@map.RoleId" />
                            <button type="submit" class="btn btn-sm btn-danger">Revoke Role</button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
